# NOTE: dotenv does NOT support inline comments. Anything after `=` is part of the value,
# including ` # …` text. Always put comments on their own line.

# Database Configuration
DATABASE_URL=postgres://user:pass@host/db

# SMTP Configuration (use 2525 for non-root testing)
SMTP_RECEIVE_PORT=25

# Heartbeat Monitoring (BetterStack Uptime, etc.)
# Leave HEARTBEAT_URL unset entirely to disable — do NOT put a comment on this line.
HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/id

# Self-hosting toggles. Set to false to disable each subsystem.
# (Names retained from the legacy Supabase era; PostgreSQL is the only backend now.)
USE_SUPABASE_BANS=true
USE_SUPABASE_DOMAINS=true